<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="16" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <!-- 标题 -->
    <Label text="女性专区" styleClass="section-title"/>

    <!-- 两栏布局 -->
    <GridPane hgap="16" vgap="16">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>

        <!-- 左栏：健康目标设定 -->
        <VBox spacing="10" styleClass="card" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label text="健康目标设定" styleClass="card-title"/>
            <Label fx:id="currentGoalLabel" text="当前目标：未设置" styleClass="goal-label"/>
            <HBox spacing="8" alignment="CENTER">
                <fx:define>
                    <ToggleGroup fx:id="goalToggleGroup"/>
                </fx:define>
                <RadioButton fx:id="weightLossRadio" text="减脂" toggleGroup="$goalToggleGroup"/>
                <RadioButton fx:id="muscleGainRadio" text="增肌" toggleGroup="$goalToggleGroup"/>
                <RadioButton fx:id="maintainRadio" text="维持" toggleGroup="$goalToggleGroup"/>
            </HBox>
            <Button fx:id="saveGoalBtn" text="保存目标" styleClass="btn-primary" onAction="#handleSaveGoal"/>
        </VBox>

        <!-- 右栏：生理周期管理 -->
        <VBox spacing="10" styleClass="card" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label text="生理周期管理" styleClass="card-title"/>
            <GridPane hgap="10" vgap="8">
                <Label text="上次经期日期" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <DatePicker fx:id="startDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="150"/>
                <Label text="周期长度(天)" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Spinner fx:id="cycleLengthSpinner" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="150"/>
            </GridPane>
            <Button fx:id="saveCycleBtn" text="保存周期" styleClass="btn-primary" onAction="#handleSaveCycle"/>
        </VBox>
    </GridPane>

    <!-- 当前阶段指示 -->
    <VBox spacing="10" styleClass="card">
        <Label text="当前阶段" styleClass="card-title"/>
        <HBox spacing="20" alignment="CENTER">
            <VBox spacing="4" alignment="CENTER">
                <Label fx:id="cyclePhaseLabel" text="未设置" styleClass="phase-label"/>
                <Label text="当前阶段" styleClass="hint-text"/>
            </VBox>
            <Separator orientation="VERTICAL" prefHeight="40"/>
            <VBox spacing="4" alignment="CENTER">
                <Label text="经期" styleClass="hint-text"/>
                <ProgressIndicator prefWidth="40" prefHeight="40" progress="1"/>
            </VBox>
            <VBox spacing="4" alignment="CENTER">
                <Label text="卵泡期" styleClass="hint-text"/>
                <ProgressIndicator prefWidth="40" prefHeight="40" progress="0.3"/>
            </VBox>
            <VBox spacing="4" alignment="CENTER">
                <Label text="排卵期" styleClass="hint-text"/>
                <ProgressIndicator prefWidth="40" prefHeight="40" progress="0.3"/>
            </VBox>
            <VBox spacing="4" alignment="CENTER">
                <Label text="黄体期" styleClass="hint-text"/>
                <ProgressIndicator prefWidth="40" prefHeight="40" progress="0.3"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- 三栏功能入口 -->
    <GridPane hgap="16" vgap="16">
        <columnConstraints>
            <ColumnConstraints percentWidth="33"/>
            <ColumnConstraints percentWidth="33"/>
            <ColumnConstraints percentWidth="33"/>
        </columnConstraints>

        <VBox spacing="8" styleClass="card" alignment="CENTER" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label text="专属食谱" styleClass="card-title"/>
            <Label text="根据周期阶段推荐" styleClass="hint-text"/>
            <Button text="查看" styleClass="btn-primary" onAction="#handleViewRecipes"/>
        </VBox>
        <VBox spacing="8" styleClass="card" alignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label text="专属匹配" styleClass="card-title"/>
            <Label text="个性化营养匹配" styleClass="hint-text"/>
            <Button text="查看" styleClass="btn-primary" onAction="#handleViewMatching"/>
        </VBox>
        <VBox spacing="8" styleClass="card" alignment="CENTER" GridPane.columnIndex="2" GridPane.rowIndex="0">
            <Label text="营养缺口分析" styleClass="card-title"/>
            <Label text="发现营养缺失" styleClass="hint-text"/>
            <Button text="查看" styleClass="btn-primary" onAction="#handleViewGapAnalysis"/>
        </VBox>
    </GridPane>
</VBox>