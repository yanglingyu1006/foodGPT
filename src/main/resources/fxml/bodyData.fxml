<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" stylesheets="@../css/main.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="身体数据管理" styleClass="section-title"/>
    <VBox spacing="10" styleClass="card">
        <GridPane hgap="10" vgap="10">
            <Label text="身高(cm):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Spinner fx:id="heightSpinner" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="150"/>
            
            <Label text="体重(kg):" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Spinner fx:id="weightSpinner" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="150"/>
            
            <Label text="年龄:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Spinner fx:id="ageSpinner" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="150"/>
            
            <Label text="活动水平:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <ComboBox fx:id="activityComboBox" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="150"/>
        </GridPane>
        
        <VBox spacing="5" styleClass="result-section">
            <Label fx:id="bmiLabel"/>
            <Label fx:id="bmrLabel"/>
            <Label fx:id="caloriesLabel"/>
        </VBox>
        
        <Button fx:id="saveBtn" text="保存数据" styleClass="btn-primary" onAction="#handleSave"/>
    </VBox>
</VBox>
