<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <!-- 顶部区域 -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="AI 健康顾问" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- 用户状态标签行 -->
        <HBox spacing="6" alignment="CENTER_RIGHT">
            <Label text="25岁" styleClass="hint-text"/>
            <Separator orientation="VERTICAL" prefHeight="16"/>
            <Label text="162cm / 58kg" styleClass="hint-text"/>
            <Separator orientation="VERTICAL" prefHeight="16"/>
            <Label text="经期第3天" styleClass="hint-text"/>
        </HBox>
        <Button fx:id="newChatBtn" text="+ 新建咨询" styleClass="btn-primary" onAction="#handleNewChat"/>
    </HBox>

    <!-- 对话消息列表 -->
    <VBox spacing="8" styleClass="card" VBox.vgrow="ALWAYS">
        <ListView fx:id="messageListView" prefHeight="420" VBox.vgrow="ALWAYS" styleClass="message-list"/>
    </VBox>

    <!-- 底部输入区域 -->
    <HBox spacing="10">
        <TextField fx:id="inputField" promptText="输入您的问题..." HBox.hgrow="ALWAYS"/>
        <Button fx:id="sendBtn" text="发送" styleClass="btn-primary" onAction="#handleSend"/>
    </HBox>
</VBox>