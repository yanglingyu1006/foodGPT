<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="用餐记录" styleClass="section-title"/>
    
    <VBox spacing="10" styleClass="card">
        <GridPane hgap="10" vgap="10">
            <Label text="日期:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="150"/>
            
            <Label text="餐型:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="mealTypeComboBox" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="150"/>
            
            <Label text="菜谱:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <ComboBox fx:id="recipeComboBox" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="150"/>
            
            <Label text="份量:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <Spinner fx:id="portionSpinner" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="150"/>
        </GridPane>
        <Button fx:id="addBtn" text="添加记录" onAction="#handleAdd"/>
    </VBox>
    
    <VBox spacing="10" styleClass="card">
        <Label text="今日记录"/>
        <ListView fx:id="recordListView" prefHeight="300"/>
        <Button text="删除选中" onAction="#handleDelete"/>
    </VBox>
</VBox>
