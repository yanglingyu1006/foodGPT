<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="16" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <!-- 顶部工具栏 -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="搜索菜谱..." prefWidth="260"/>
        <ComboBox fx:id="categoryComboBox" prefWidth="120"/>
        <Button fx:id="searchBtn" text="搜索" styleClass="btn-primary" onAction="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ 新建菜谱" styleClass="btn-primary"/>
    </HBox>

    <!-- 菜谱卡片网格 -->
    <ScrollPane fitToWidth="true" styleClass="card" VBox.vgrow="ALWAYS">
        <TilePane fx:id="recipeTilePane" hgap="12" vgap="12" prefColumns="3"/>
    </ScrollPane>

    <!-- 菜谱列表 -->
    <VBox spacing="10" styleClass="card">
        <Label text="全部菜谱" styleClass="card-title"/>
        <ListView fx:id="recipeListView" prefHeight="200"/>
        <HBox spacing="10">
            <Button text="删除选中" styleClass="btn-danger" onAction="#handleDelete"/>
        </HBox>
    </VBox>

    <!-- 分页控件 -->
    <HBox spacing="8" alignment="CENTER">
        <Button text="上一页" styleClass="btn-outline"/>
        <Label fx:id="pageLabel" text="第 1/3 页" styleClass="hint-text"/>
        <Button text="下一页" styleClass="btn-outline"/>
    </HBox>
</VBox>