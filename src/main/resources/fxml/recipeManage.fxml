<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="菜谱管理" styleClass="section-title"/>
    
    <HBox spacing="10">
        <TextField fx:id="searchField" promptText="搜索菜谱" prefWidth="200"/>
        <ComboBox fx:id="categoryComboBox" prefWidth="120"/>
        <Button fx:id="searchBtn" text="搜索" onAction="#handleSearch"/>
    </HBox>
    
    <VBox spacing="10" styleClass="card">
        <ListView fx:id="recipeListView" prefHeight="400"/>
        <Button text="删除选中" onAction="#handleDelete"/>
    </VBox>
</VBox>
