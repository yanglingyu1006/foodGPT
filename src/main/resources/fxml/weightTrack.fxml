<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="16" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <Label text="体重追踪" styleClass="section-title"/>

    <!-- 添加记录 -->
    <VBox spacing="10" styleClass="card">
        <GridPane hgap="10" vgap="10">
            <Label text="体重(kg)" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Spinner fx:id="weightInput" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="150"/>
            <Label text="日期" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="150"/>
        </GridPane>
        <Button fx:id="addBtn" text="添加记录" styleClass="btn-primary" onAction="#handleAdd"/>
    </VBox>

    <!-- 历史记录列表 -->
    <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
        <Label text="历史记录" styleClass="card-title"/>
        <ListView fx:id="recordListView" prefHeight="400" VBox.vgrow="ALWAYS"/>
        <HBox spacing="10">
            <Button text="删除选中" styleClass="btn-danger" onAction="#handleDelete"/>
        </HBox>
    </VBox>
</VBox>